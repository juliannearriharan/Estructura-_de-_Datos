#include <iostream>
#define MAX 100
using namespace std;

typedef int TipoDato;

class Pila
{
private:
    TipoDato pila[MAX];
    int cima;
    
public:
    Pila();
    bool Apilar(TipoDato elemento);
    void LimpiarPila();
    bool PilaVacia();
};
    
Pila::Pila()
    {
        cima = -1;
    }

bool Pila::Apilar(TipoDato elemento)
    {
        if (cima == MAX - 1)
        {
            cout << "Overflow: pila llena" << endl;
            return false;
        }
        cima++;
        pila[cima] = elemento;
        return true;
    }

void Pila::LimpiarPila()
    {
        cima = -1;
    }

bool Pila::PilaVacia()
    {
        return cima == -1;
    }


// ---------------- MAIN ----------------
int main()
{
    Pila p;
    int n, dato;

    cout << "Cuantos elementos desea ingresar? ";
    cin >> n;

    // Ingreso de datos
    for (int i = 0; i < n; i++)
    {
        cout << "Ingrese elemento " << i + 1 << ": ";
        cin >> dato;
        p.Apilar(dato);
    }

    // Limpiar pila
    cout << "\nLimpiando la pila..." << endl;
    p.LimpiarPila();


    if (p.PilaVacia())
    {
        cout << "La pila esta vacia correctamente." << endl;
    }
    else
    {
        cout << "Error: la pila no se vacio." << endl;
    }

    return 0;
}
